async def check_channels_subscription(user_id: int) -> tuple[bool, list]:
    """Проверяет подписку на все обязательные каналы (админы пропускаются)"""
    
    # Админы не проверяются
    if user_id in ADMIN_IDS:
        return True, []
    
    not_subscribed = []
    channels = REQUIRED_CHANNELS
    
    for channel in channels:
        try:
            member = await bot.get_chat_member(channel, user_id)
            if member.status not in ['member', 'administrator', 'creator']:
                not_subscribed.append(channel)
        except Exception as e:
            print(f"Ошибка проверки подписки на {channel}: {e}")
            not_subscribed.append(channel)
    return len(not_subscribed) == 0, not_subscribed

async def check_target_subscription(user_id: int, channel_url: str) -> bool:
    """Проверяет подписку на целевой канал (для заданий)"""
    try:
        channel = channel_url.replace('https://t.me/', '').replace('http://t.me/', '').replace('@', '').split('/')[0]
        channel = channel.split('?')[0]
        if not channel:
            return False
        member = await bot.get_chat_member(f'@{channel}', user_id)
        return member.status in ['member', 'administrator', 'creator']
    except:
        return True

async def get_publish_channel() -> str:
    """Возвращает текущий канал для публикации из базы (или значение по умолчанию)"""
    async with aiosqlite.connect(DB_PATH) as db:
        cur = await db.execute('SELECT value FROM bot_config WHERE key="publish_channel"')
        row = await cur.fetchone()
        if row:
            return row[0]
    return DEFAULT_CHANNEL_ID

async def set_publish_channel(channel: str):
    """Устанавливает канал для публикации в базе"""
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute('INSERT OR REPLACE INTO bot_config (key, value) VALUES (?, ?)',
                         ('publish_channel', channel))
        await db.commit()

async def publish_to_channel(text: str, parse_mode: str = "HTML", reply_markup=None):
    """Публикует сообщение в текущий канал для публикаций"""
    channel = await get_publish_channel()
    try:
        await bot.send_message(
            channel,
            text,
            parse_mode=parse_mode,
            reply_markup=reply_markup,
            message_thread_id=None
        )
    except Exception as e:
        print(f"Ошибка публикации в канал {channel}: {e}")

async def broadcast_to_users(message_text: str, exclude_admin: bool = True):
    async with aiosqlite.connect(DB_PATH) as db:
        db.row_factory = aiosqlite.Row
        cursor = await db.execute('SELECT user_id FROM users')
        users = await cursor.fetchall()
    success, fail = 0, 0
    for user in users:
        uid = user['user_id']
        if exclude_admin and uid in ADMIN_IDS:
            continue
        try:
            await bot.send_message(uid, message_text, parse_mode="HTML")
            success += 1
            await asyncio.sleep(0.05)
        except:
            fail += 1
    return success, fail


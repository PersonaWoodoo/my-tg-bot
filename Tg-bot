async def complete_task(update, tid, user, state):
    async with aiosqlite.connect(DB_PATH) as db:
        cur = await db.execute('SELECT remaining_quantity, reward_gmp FROM tasks WHERE id=?', (tid,))
        row = await cur.fetchone()
        if not row:
            await (update.message.edit_text if hasattr(update,'message') else update.edit_text)("❌ Задание не найдено")
            await state.clear()
            return
        rem, rew = row
        if rem <= 0:
            await (update.message.edit_text if hasattr(update,'message') else update.edit_text)("❌ Уже выполнено")
            await state.clear()
            return
        cur2 = await db.execute('SELECT id FROM completions WHERE user_id=? AND task_id=?', (user['id'], tid))
        if await cur2.fetchone():
            await (update.message.edit_text if hasattr(update,'message') else update.edit_text)("❌ Уже выполнено")
            await state.clear()
            return
        await db.execute('UPDATE users SET balance_gmp=balance_gmp+?, tasks_completed=tasks_completed+1 WHERE id=?', (rew, user['id']))
        await db.execute('UPDATE tasks SET remaining_quantity=remaining_quantity-1 WHERE id=?', (tid,))
        await db.execute('INSERT INTO completions (user_id, task_id) VALUES (?,?)', (user['id'], tid))
        await db.commit()
    await (update.message.edit_text if hasattr(update,'message') else update.edit_text)(f"✅ Задание выполнено! Получено {rew} GMP")
    await state.clear()


async def activate_check_by_code(message: types.Message, code: str):
    """Активация чека по коду"""
    code = code.upper()
    user = await get_user(message.from_user.id)
    if not user:
        await message.answer("❌ Сначала /start")
        return
    
    async with aiosqlite.connect(DB_PATH) as db:
        db.row_factory = aiosqlite.Row
        
        # Ищем чек
        cur = await db.execute('SELECT * FROM checks WHERE code=? AND is_active=1', (code,))
        ch = await cur.fetchone()
        if not ch:
            await message.answer("❌ Чек не найден или уже деактивирован")
            return
        
        chd = dict(ch)
        
        # Проверяем, активировал ли этот пользователь уже данный чек
        cur2 = await db.execute('SELECT id FROM check_activations WHERE user_id=? AND check_id=?', 
                               (user['id'], chd['id']))
        if await cur2.fetchone():
            await message.answer("❌ Вы уже активировали этот чек")
            return
        
        # Проверяем общий лимит активаций чека
        if chd['max_activations'] > 0 and chd['activations_count'] >= chd['max_activations']:
            # Деактивируем чек, если лимит исчерпан
            await db.execute('UPDATE checks SET is_active=0 WHERE id=?', (chd['id'],))
            await db.commit()
            await message.answer("❌ Чек исчерпал лимит активаций")
            return
        
        # Начисляем бонус
        await db.execute('UPDATE users SET balance_gmp=balance_gmp+? WHERE id=?', (chd['amount'], user['id']))
        
        # Записываем активацию
        await db.execute('INSERT INTO check_activations (user_id, check_id) VALUES (?,?)', 
                        (user['id'], chd['id']))
        
        # Увеличиваем счётчик активаций чека
        new_count = chd['activations_count'] + 1
        if chd['max_activations'] > 0 and new_count >= chd['max_activations']:
            # Если достигнут лимит, деактивируем чек
            await db.execute('UPDATE checks SET activations_count=?, is_active=0 WHERE id=?',
                             (new_count, chd['id']))
        else:
            await db.execute('UPDATE checks SET activations_count=? WHERE id=?',
                             (new_count, chd['id']))
        
        await db.commit()
    
    await message.answer(f"✅ Чек активирован! Получено {chd['amount']} GMP")

async def activate_promo_by_code(message: types.Message, code: str):
    """Активация промо-кода по коду"""
    code = code.upper()
    user = await get_user(message.from_user.id)
    if not user:
        await message.answer("❌ Сначала /start")
        return
    
    async with aiosqlite.connect(DB_PATH) as db:
        db.row_factory = aiosqlite.Row
        cur = await db.execute('SELECT * FROM promocodes WHERE code=? AND is_active=1', (code,))
        promo = await cur.fetchone()
        if not promo:
            await message.answer("❌ Промо-код не найден или уже деактивирован")
            return
        p = dict(promo)
        cur2 = await db.execute('SELECT id FROM promo_activations WHERE user_id=? AND promo_id=?', (user['id'], p['id']))

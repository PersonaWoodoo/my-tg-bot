async def generate_auto_check(admin_id: int, amount: float, description: str, max_activations: int):
    """Генерирует и публикует один авто-чек"""
    # Генерируем код
    code = await generate_check_code()
    bot_username = (await bot.get_me()).username
    activation_link = f"https://t.me/{bot_username}?start={code}"
    
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            # Создаём чек в БД
            await db.execute('''
                INSERT INTO checks (creator_id, amount, code, description, max_activations) 
                VALUES (?, ?, ?, ?, ?)
            ''', (admin_id, amount, code, description, max_activations))
            
            # Списываем средства
            await db.execute('UPDATE users SET balance_gmp = balance_gmp - ? WHERE id = ?', (amount, admin_id))
            await db.commit()
    except Exception as e:
        logging.error(f"Ошибка при генерации авто-чека: {e}")
        return
    
    # Публикуем в канал
    channel_message = f"<b>🎄 АВТО-ЧЕК</b>\n\n💰 <b>{amount} GMP</b>\n"
    if description:
        channel_message += f"📝 {description}\n"
    channel_message += f"\n👇 Нажмите кнопку для активации"
    
    channel_kb = InlineKeyboardMarkup(
        inline_keyboard=[[InlineKeyboardButton(text="🎁 ПОЛУЧИТЬ", url=activation_link)]]
    )
    
    await publish_to_channel(channel_message, reply_markup=channel_kb)

# Запуск фоновой задачи для авто-чеков
async def auto_checks_worker():
    while True:
        try:
            async with aiosqlite.connect(DB_PATH) as db:
                db.row_factory = aiosqlite.Row
                now = datetime.now()
                
                # Ищем все активные авто-чеки, у которых прошёл интервал
                cur = await db.execute('''
                    SELECT * FROM auto_checks 
                    WHERE is_active=1 
                    AND (
                        last_generated IS NULL 
                        OR datetime(last_generated) <= datetime(?, '-' || interval_minutes || ' minutes')
                    )
                ''', (now.isoformat(),))
                
                auto_checks = await cur.fetchall()
                
                for ac in auto_checks:
                    acd = dict(ac)
                    await generate_auto_check(
                        acd['creator_id'], 
                        acd['amount'], 
                        acd['description'], 
                        acd['max_activations']
                    )
                    
                    # Обновляем время последней генерации
                    await db.execute('''
                        UPDATE auto_checks SET last_generated=? WHERE id=?
                    ''', (now.isoformat(), acd['id']))
                
                await db.commit()
        except Exception as e:
            logging.error(f"Ошибка в авто-чеках: {e}")
        
        # Проверяем каждую минуту
        await asyncio.sleep(60)

